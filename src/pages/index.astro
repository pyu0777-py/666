    <div id="responsive-image-catalog" data-json={encodeURIComponent(JSON.stringify(runtimeResponsiveImageCatalog))} hidden></div>

    <script>
        const runtimeResponsiveImageCatalogElement = document.getElementById('responsive-image-catalog');
        const runtimeResponsiveImageCatalog = runtimeResponsiveImageCatalogElement instanceof HTMLElement && runtimeResponsiveImageCatalogElement.dataset.json
            ? JSON.parse(decodeURIComponent(runtimeResponsiveImageCatalogElement.dataset.json))
            : {};

        function getRuntimeResponsiveImageData(src: string) {
            if (runtimeResponsiveImageCatalog[src]) {
                return runtimeResponsiveImageCatalog[src];
            }

            if (/^https?:\/\/images\.unsplash\.com\//i.test(src)) {
                const url = new URL(src);
                const originalWidth = Number(url.searchParams.get('w') || '1600');
                const widths = [240, 360, 480, 640, 960, 1280].filter((width) => width < originalWidth);
                return {
                    src,
                    srcset: [...widths, originalWidth].map((width) => {
                        const variant = new URL(url.toString());
                        variant.searchParams.set('w', String(width));
                        return `${variant.toString()} ${width}w`;
                    }).join(', '),
                    width: originalWidth,
                };
            }

            if (/^https?:\/\/placehold\.co\//i.test(src)) {
                const url = new URL(src);
                const match = url.pathname.match(/\/(\d+)x(\d+)(?=\/|$)/i);
                if (match) {
                    const originalWidth = Number(match[1]);
                    const originalHeight = Number(match[2]);
                    const widths = [240, 360, 480, 640, 960, 1280].filter((width) => width < originalWidth);
                    return {
                        src,
                        srcset: [...widths, originalWidth].map((width) => {
                            const height = Math.round((originalHeight / originalWidth) * width);
                            return `${src.replace(`/${originalWidth}x${originalHeight}/`, `/${width}x${height}/`)} ${width}w`;
                        }).join(', '),
                        width: originalWidth,
                        height: originalHeight,
                    };
                }
            }

            return { src };
        }

        function getResponsiveImageTagAttributes(src: string, sizes = '100vw') {
            const data = getRuntimeResponsiveImageData(src);
            const attrs = [
                `src="${data.src}"`,
                `sizes="${sizes}"`,
                `loading="lazy"`,
                `decoding="async"`,
            ];

            if (data.srcset) attrs.push(`srcset="${data.srcset}"`);
            if (data.width) attrs.push(`width="${data.width}"`);
            if (data.height) attrs.push(`height="${data.height}"`);

            return attrs.join(' ');
        }

        // === 平滑滚动 ===
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const href = anchor.getAttribute('href');
                const target = href ? document.querySelector<HTMLElement>(href) : null;
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // === 作品过滤与瀑布图集 ===
        const workGridWrap = document.getElementById('workGridWrap');
        const worksSection = document.getElementById('works');
        const workGrid = document.getElementById('workGrid');
        const workPagination = document.getElementById('workPagination');
        const workPageNumbers = document.getElementById('workPageNumbers');
        const workPageVisual = document.getElementById('workPageVisual');
        const paginationPrevBtn = workPagination?.querySelector<HTMLButtonElement>('.page-nav.prev');
        const paginationNextBtn = workPagination?.querySelector<HTMLButtonElement>('.page-nav.next');
        const waterfallPanel = document.getElementById('waterfallPanel');
        const mainCardsPerPage = 32;
        const mobileUnifiedFilters = new Set(['main', 'aplus', 'video', 'brand', 'packaging', 'ces', 'other']);
        let currentFilter = 'waterfall';
        let currentMainPage = 1;
        let visibleMainCards: HTMLElement[] = [];

        function isDesktopViewport() {
            return window.matchMedia('(min-width: 769px)').matches;
        }

        function isMobileViewport() {
            return window.matchMedia('(max-width: 768px)').matches;
        }

        function toggleMainMobileScrollLayout() {
            if (!(workGrid instanceof HTMLElement)) return;
            const shouldEnable = mobileUnifiedFilters.has(currentFilter) && isMobileViewport();
            workGrid.classList.toggle('mobile-main-scroll', shouldEnable);
        }

        function updateMainPaginationUI(totalPages: number) {
            if (!workPagination || !workPageNumbers || !workPageVisual) return;

            workPageNumbers.innerHTML = '';
            workPageVisual.innerHTML = '';

            for (let page = 1; page <= totalPages; page++) {
                const numberBtn = document.createElement('button');
                numberBtn.type = 'button';
                numberBtn.className = `page-number${page === currentMainPage ? ' active' : ''}`;
                numberBtn.textContent = String(page);
                numberBtn.setAttribute('aria-label', `跳转到第 ${page} 页`);
                numberBtn.addEventListener('click', () => renderMainPage(page, true));
                workPageNumbers.appendChild(numberBtn);

                const visualBtn = document.createElement('button');
                visualBtn.type = 'button';
                visualBtn.className = `page-visual-dot${page === currentMainPage ? ' active' : ''}`;
                visualBtn.setAttribute('aria-label', `可视化跳转到第 ${page} 页`);
                visualBtn.addEventListener('click', () => renderMainPage(page, true));
                workPageVisual.appendChild(visualBtn);
            }

            if (paginationPrevBtn) {
                paginationPrevBtn.disabled = currentMainPage <= 1;
            }
            if (paginationNextBtn) {
                paginationNextBtn.disabled = currentMainPage >= totalPages;
            }
        }

        function renderMainPage(targetPage: number, scrollToTop = false) {
            if (!visibleMainCards.length) {
                if (workPagination) workPagination.hidden = true;
                return;
            }

            if (!isDesktopViewport() || currentFilter !== 'main') {
                visibleMainCards.forEach((card) => {
                    card.style.removeProperty('display');
                });
                if (workPagination) workPagination.hidden = true;
                return;
            }

            const totalPages = Math.max(1, Math.ceil(visibleMainCards.length / mainCardsPerPage));
            currentMainPage = Math.min(Math.max(targetPage, 1), totalPages);
            const start = (currentMainPage - 1) * mainCardsPerPage;
            const end = start + mainCardsPerPage;

            visibleMainCards.forEach((card, index) => {
                if (index >= start && index < end) {
                    card.style.removeProperty('display');
                } else {
                    card.style.display = 'none';
                }
            });

            if (workPagination) {
                workPagination.hidden = totalPages <= 1;
            }
            updateMainPaginationUI(totalPages);

            if (scrollToTop) {
                worksSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        function refreshMainPagination(cards: HTMLElement[]) {
            visibleMainCards = cards;
            currentMainPage = 1;
            renderMainPage(currentMainPage, false);
        }

        function setWaterfallMode(isWaterfall: boolean) {
            if (workGridWrap) workGridWrap.style.display = isWaterfall ? 'none' : '';
            if (waterfallPanel) waterfallPanel.classList.toggle('active', isWaterfall);
            if (isWaterfall && workPagination) {
                workPagination.hidden = true;
            }
        }

        function filterWorks(type: string, button: HTMLElement | null) {
            const cards = document.querySelectorAll<HTMLElement>('.project-card');
            const buttons = document.querySelectorAll<HTMLElement>('.filter-btn');
            currentFilter = type;

            buttons.forEach(btn => btn.classList.remove('active'));
            if (button) {
                button.classList.add('active');
            }

            if (type === 'waterfall') {
                setWaterfallMode(true);
                return;
            }

            setWaterfallMode(false);

            cards.forEach(card => {
                const isDirectoryMainCard = card.dataset.type === 'main' && card.dataset.source === 'directory';
                if (type === 'all' || (type === 'main' && isDirectoryMainCard) || (type !== 'main' && card.dataset.type === type)) {
                    card.style.removeProperty('display');
                } else {
                    card.style.display = 'none';
                }
            });

            if (type === 'main') {
                const mainCards = Array.from(cards).filter((card) => card.dataset.type === 'main' && card.dataset.source === 'directory');
                refreshMainPagination(mainCards);
            } else {
                visibleMainCards = [];
                if (workPagination) workPagination.hidden = true;
            }

            toggleMainMobileScrollLayout();
        }

        paginationPrevBtn?.addEventListener('click', () => {
            renderMainPage(currentMainPage - 1, true);
        });

        paginationNextBtn?.addEventListener('click', () => {
            renderMainPage(currentMainPage + 1, true);
        });

        window.addEventListener('resize', () => {
            toggleMainMobileScrollLayout();

            if (currentFilter !== 'main') return;

            const cards = Array.from(document.querySelectorAll<HTMLElement>('.project-card')).filter(
                (card) => card.dataset.type === 'main' && card.dataset.source === 'directory'
            );
            refreshMainPagination(cards);
        });

        document.querySelectorAll<HTMLElement>('.filter-btn').forEach(button => {
            button.addEventListener('click', () => {
                filterWorks(button.dataset.filter || 'all', button);
            });
        });

        const defaultFilterBtn = document.querySelector<HTMLElement>('.filter-btn.active');
        if (defaultFilterBtn) {
            filterWorks(defaultFilterBtn.dataset.filter || 'all', defaultFilterBtn);
        }

        const chartPreview = document.getElementById('chartPreview');
        const overlay = document.getElementById('lightboxOverlay');
        const lightboxGallery = document.getElementById('lightboxGallery');
        const lightboxCaption = document.getElementById('lightboxCaption');
        const lightboxClose = document.getElementById('lightboxClose');
        const lightboxPrev = document.getElementById('lightboxPrev');
        const lightboxNext = document.getElementById('lightboxNext');
        const methodChart = document.getElementById('methodChart');
        type LightboxMediaItem = {
            type: 'image' | 'video';
            src: string;
        };

        let currentLightboxMedia: LightboxMediaItem[] = [];
        let currentLightboxIndex = 0;
        let previousBodyOverflow = '';

        function getMediaMimeType(src: string) {
            const cleanSrc = src.split('?')[0].toLowerCase();
            if (cleanSrc.endsWith('.webm')) return 'video/webm';
            if (cleanSrc.endsWith('.mov')) return 'video/quicktime';
            return 'video/mp4';
        }

        function syncLightboxVideoPlayback() {
            if (!lightboxGallery || !currentLightboxMedia.length) return;

            const mediaNodes = lightboxGallery.querySelectorAll<HTMLElement>('[data-lightbox-item]');
            mediaNodes.forEach((node, nodeIndex) => {
                if (!(node instanceof HTMLVideoElement)) return;

                if (nodeIndex !== currentLightboxIndex) {
                    node.pause();
                    return;
                }

                node.defaultMuted = true;
                node.muted = true;
                node.playsInline = true;
                node.load();
                node.play().catch(() => {
                    // User can still press the play button in controls if autoplay is blocked.
                });
            });
        }

        function openLightbox(media: LightboxMediaItem[], index = 0) {
            if (!overlay || !lightboxGallery || !lightboxCaption) return;
            currentLightboxMedia = media;
            currentLightboxIndex = index;
            lightboxGallery.innerHTML = media.map((item, mediaIndex) => `
                ${item.type === 'video'
                    ? `<video data-lightbox-item controls autoplay loop muted playsinline preload="metadata"><source src="${item.src}" type="${getMediaMimeType(item.src)}" /></video>`
                    : `<img data-lightbox-item ${getResponsiveImageTagAttributes(item.src, '100vw')} alt="作品图 ${mediaIndex + 1}">`
                }
            `).join('');
            const scrollArea = lightboxGallery.parentElement as HTMLElement | null;
            lightboxCaption.textContent = media.length > 1 ? `共 ${media.length} 项，向下滚动查看` : (media[0]?.type === 'video' ? '作品视频' : '作品大图');
            overlay.classList.add('active');
            previousBodyOverflow = document.body.style.overflow;
            document.body.style.overflow = 'hidden';
            requestAnimationFrame(() => {
                const targetMedia = lightboxGallery.querySelectorAll<HTMLElement>('[data-lightbox-item]')[currentLightboxIndex];
                targetMedia?.scrollIntoView({ behavior: 'auto', block: 'start' });
                if (scrollArea) scrollArea.scrollTop = 0;
                syncLightboxVideoPlayback();
            });
        }

        function openLightboxImages(images: string[], index = 0) {
            openLightbox(images.map((src) => ({ type: 'image', src })), index);
        }

        function closeLightbox() {
            if (overlay) overlay.classList.remove('active');
            lightboxGallery?.querySelectorAll('video').forEach((video) => {
                if (video instanceof HTMLVideoElement) {
                    video.pause();
                }
            });
            document.body.style.overflow = previousBodyOverflow;
        }

        function openMethodologyLightbox() {
            const imageSrc = methodChart?.getAttribute('data-image') || '/1shouye/2suo.png';
            if (
                overlay?.classList.contains('active') &&
                currentLightboxMedia.length === 1 &&
                currentLightboxMedia[0].type === 'image' &&
                currentLightboxMedia[0].src === imageSrc
            ) {
                closeLightbox();
                return;
            }
            openLightboxImages([imageSrc], 0);
        }

        function showLightboxImage(index: number) {
            if (!lightboxGallery || !lightboxCaption || !currentLightboxMedia.length) return;
            currentLightboxIndex = (index + currentLightboxMedia.length) % currentLightboxMedia.length;
            const targetMedia = lightboxGallery.querySelectorAll<HTMLElement>('[data-lightbox-item]')[currentLightboxIndex];
            targetMedia?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            if (currentLightboxMedia.length > 1) {
                lightboxCaption.textContent = `作品 ${currentLightboxIndex + 1}/${currentLightboxMedia.length}`;
            } else {
                lightboxCaption.textContent = currentLightboxMedia[0].type === 'video' ? '作品视频' : '作品大图';
            }
            syncLightboxVideoPlayback();
        }

        function getProjectLightboxMedia(card: HTMLElement): LightboxMediaItem[] {
            const baseImages = [
                'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1495707902641-75cac588d2e9?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=600&q=80'
            ];
            const customImages = JSON.parse(card.dataset.images || '[]') as string[];
            const customVideos = JSON.parse(card.dataset.videos || '[]') as string[];
            const isDirectoryCard = card.dataset.source === 'directory';
            if (isDirectoryCard && !customImages.length && !customVideos.length) {
                return [];
            }

            const media: LightboxMediaItem[] = [];
            if (customVideos.length) {
                media.push(...customVideos.map((src) => ({ type: 'video' as const, src })));
            }
            if (customImages.length) {
                media.push(...customImages.map((src) => ({ type: 'image' as const, src })));
            }
            if (media.length) {
                return media;
            }

            const sourceImages = customImages.length ? customImages : baseImages;
            return Array.from({ length: sourceImages.length }, (_, index) => ({ type: 'image' as const, src: sourceImages[index] }));
        }

        function ensureMainCardsSupportVideos() {
            const defaultMainVideos = [
                'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4',
                'https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.webm'
            ];

            document.querySelectorAll<HTMLElement>('.project-card[data-type="main"]').forEach((card) => {
                if (card.dataset.source === 'directory') return;

                let customVideos: string[] = [];
                try {
                    customVideos = JSON.parse(card.dataset.videos || '[]') as string[];
                } catch {
                    customVideos = [];
                }

                if (!customVideos.length) {
                    customVideos = defaultMainVideos;
                    card.dataset.videos = JSON.stringify(customVideos);
                }

                const thumb = card.querySelector<HTMLElement>('.project-thumb');
                if (!thumb || thumb.querySelector('.project-preview-video')) return;

                const coverImg = thumb.querySelector<HTMLImageElement>('img');
                if (!coverImg) return;

                const posterSrc = coverImg.getAttribute('src') || '';
                const videoSrc = customVideos[0];
                if (!videoSrc) return;

                thumb.innerHTML = `
                    <video class="project-preview-video" autoplay muted loop playsinline preload="metadata" poster="${posterSrc}" aria-label="主图视频预览">
                        <source src="${videoSrc}" type="${getMediaMimeType(videoSrc)}" />
                    </video>
                    ${posterSrc ? `<img class="video-fallback-image" ${getResponsiveImageTagAttributes(posterSrc, '(max-width: 480px) 50vw, (max-width: 768px) 33vw, 280px')} alt="${coverImg.alt || '主图封面'}" />` : ''}
                `;
            });
        }

        ensureMainCardsSupportVideos();

        document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
            card.addEventListener('click', () => {
                const media = getProjectLightboxMedia(card);
                if (media.length) {
                    openLightbox(media, 0);
                }
            });
        });

        document.querySelectorAll<HTMLVideoElement>('.project-preview-video').forEach(video => {
            const thumb = video.closest<HTMLElement>('.project-thumb');
            if (!thumb) return;

            const showFallback = () => {
                thumb.classList.add('video-error');
            };

            const hideFallback = () => {
                thumb.classList.remove('video-error');
            };

            const tryPlayPreview = () => {
                video.play().then(() => {
                    hideFallback();
                }).catch(() => {
                    // Mobile browsers may delay autoplay until the video is visible.
                });
            };

            video.defaultMuted = true;
            video.muted = true;
            video.autoplay = true;
            video.loop = true;
            video.playsInline = true;
            video.setAttribute('muted', '');
            video.setAttribute('autoplay', '');
            video.setAttribute('playsinline', '');
            video.setAttribute('webkit-playsinline', 'true');

            if (video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
                hideFallback();
                tryPlayPreview();
            }

            video.addEventListener('loadeddata', hideFallback);
            video.addEventListener('loadedmetadata', tryPlayPreview);
            video.addEventListener('canplay', () => {
                hideFallback();
                tryPlayPreview();
            });
            video.addEventListener('playing', hideFallback);
            video.addEventListener('error', showFallback);
            video.addEventListener('suspend', () => {
                if (video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
                    hideFallback();
                }
            });

            const visibilityObserver = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (!entry.isIntersecting) {
                        video.pause();
                        return;
                    }

                    tryPlayPreview();
                });
            }, { threshold: 0.35 });

            visibilityObserver.observe(video);
        });

        document.querySelectorAll<HTMLElement>('.rank-item').forEach(item => {
            item.addEventListener('click', () => {
                const isExpanded = item.classList.contains('expanded');
                document.querySelectorAll<HTMLElement>('.rank-item').forEach(otherItem => {
                    otherItem.classList.remove('expanded');
                    const gallery = otherItem.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery) gallery.innerHTML = '';
                });

                if (!isExpanded) {
                    item.classList.add('expanded');
                    const images = JSON.parse(item.dataset.images || '[]') as string[];
                    const gallery = item.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery && images.length) {
                        const displayImages = Array.from({ length: 25 }, (_, index: number) => `${images[index % images.length]}&sig=${index}`);
                        gallery.innerHTML = displayImages.slice(0, 10).map((src, index: number) => {
                            if (index === 9) {
                                return `<div class="gallery-more">+${displayImages.length - 9} 张</div>`;
                            }
                            return `<img ${getResponsiveImageTagAttributes(src, '50vw')} alt="爆款案例图片" data-index="${index}">`;
                        }).join('');
                        gallery.querySelectorAll<HTMLImageElement>('img').forEach((img, index) => {
                            img.addEventListener('click', (event) => {
                                event.stopPropagation();
                                openLightboxImages(displayImages, index);
                            });
                        });
                    }
                }
            });
        });

        if (chartPreview) {
            chartPreview.addEventListener('click', () => {
                openLightboxImages([
                    'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1400&q=80'
                ], 0);
            });
        }

        methodChart?.addEventListener('click', openMethodologyLightbox);

        lightboxGallery?.addEventListener('click', (event) => {
            const target = event.target;
            if (target instanceof HTMLImageElement && currentLightboxMedia.length === 1) {
                closeLightbox();
            }
        });

        if (overlay) {
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) closeLightbox();
            });
        }
        if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
        if (lightboxPrev) lightboxPrev.addEventListener('click', () => showLightboxImage(currentLightboxIndex - 1));
        if (lightboxNext) lightboxNext.addEventListener('click', () => showLightboxImage(currentLightboxIndex + 1));
        document.addEventListener('keydown', (event) => {
            if (!overlay?.classList.contains('active')) return;
            if (event.key === 'Escape') closeLightbox();
            if (event.key === 'ArrowRight') showLightboxImage(currentLightboxIndex + 1);
            if (event.key === 'ArrowLeft') showLightboxImage(currentLightboxIndex - 1);
        });

        // === 原生 JS 数字滚动动画 ===
        function animateCountUp(el: HTMLElement) {
            const target = parseInt(el.dataset.target || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 2000; // 2秒动画
            const step = target / (duration / 16); // 每帧增加的数值
            let current = 0;

            const timer = setInterval(() => {
                current += step;
                if (current >= target) {
                    el.innerText = target + suffix;
                    clearInterval(timer);
                } else {
                    el.innerText = Math.ceil(current) + suffix;
                }
            }, 16);
        }

        // === 监听滚动触发数字动画 ===
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting && entry.target instanceof HTMLElement) {
                    animateCountUp(entry.target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.count-up').forEach(el => observer.observe(el));

        // === 编辑模式开关 ===
        let clickCount = 0;
        let clickTimer: ReturnType<typeof setTimeout> | null = null;
        const logo = document.getElementById('logo-trigger');
        const indicator = document.getElementById('edit-mode-indicator');

        if (logo) {
            logo.addEventListener('click', () => {
                clickCount++;
                if (clickCount === 1) {
                    clickTimer = setTimeout(() => {
                        clickCount = 0;
                    }, 1000); // 1秒内点击3次
                } else if (clickCount === 3) {
                    if (clickTimer) clearTimeout(clickTimer);
                    clickCount = 0;
                    
                    const isEditable = document.body.contentEditable === 'true';
                    document.body.contentEditable = isEditable ? 'false' : 'true';
                    
                    if (indicator) {
                        indicator.style.display = isEditable ? 'none' : 'block';
                        setTimeout(() => {
                            if (!isEditable && indicator) indicator.style.display = 'none';
                        }, 2000);
                    }
                }
            });
        }

        // === 移动端导航 开关 ===
        const mobileToggle = document.getElementById('mobile-nav-toggle');
        const mobileNav = document.getElementById('mobileNav');
        const mobileCloseBtn = document.getElementById('mobileNavClose');
        function openMobileNav() {
            if (mobileNav) {
                mobileNav.classList.add('open');
                mobileNav.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }
        }
        function closeMobileNav() {
            if (mobileNav) {
                mobileNav.classList.remove('open');
                mobileNav.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }
        }
        mobileToggle?.addEventListener('click', openMobileNav);
        mobileCloseBtn?.addEventListener('click', closeMobileNav);
        document.querySelectorAll('.mobile-nav a').forEach(a => a.addEventListener('click', closeMobileNav));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMobileNav(); });
        // contact avatar replace & copy email/wechat
        const contactAvatar = document.getElementById('contactAvatar') as HTMLImageElement | null;
        const copyEmailBtn = document.getElementById('copyEmail');
        const copyWeChatBtn = document.getElementById('copyWeChat');
        // load saved avatar
        try {
            const saved = localStorage.getItem('contactAvatarSrc');
            if (saved && contactAvatar) contactAvatar.src = saved;
        } catch (e) { }
        copyEmailBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            const text = '312675265@qq.com';
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(() => alert('Email 已复制：' + text));
            } else {
                const input = document.createElement('input');
                input.value = text;
                document.body.appendChild(input);
                input.select();
                document.execCommand('copy');
                document.body.removeChild(input);
                alert('Email 已复制：' + text);
            }
        });

        copyWeChatBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            const text = 'YIYUANYUYU';
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(() => alert('WeChat 已复制：' + text));
            } else {
                alert('请手动复制：' + text);
            }
        });
    </script>
</body>
</html>