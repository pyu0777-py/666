    <script>
        // === 平滑滚动 ===
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const href = anchor.getAttribute('href');
                const target = href ? document.querySelector<HTMLElement>(href) : null;
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });

        // === 作品过滤与瀑布图集 ===
        const workGridWrap = document.getElementById('workGridWrap');
        const waterfallPanel = document.getElementById('waterfallPanel');
        const waterfallGrid = document.getElementById('waterfallGrid');
        const waterfallMoreBtn = document.getElementById('waterfallMoreBtn');
        const waterfallPalette = [
            '#ff9f1c', '#ff6b6b', '#f368e0', '#a55eea', '#54a0ff', '#00d2d3',
            '#1dd1a1', '#48dbfb', '#feca57', '#ff7f50', '#6c5ce7', '#2d98da',
            '#20bf6b', '#fd9644', '#eb3b5a', '#778ca3', '#3867d6', '#0fb9b1'
        ];
        const waterfallHeights = [120, 150, 180, 210, 240, 270, 300, 330];
        const waterfallBlocks = Array.from({ length: 90 }, (_, index) => ({
            color: waterfallPalette[index % waterfallPalette.length],
            height: waterfallHeights[(index * 5 + 3) % waterfallHeights.length]
        }));
        const waterfallBatchSize = 24;
        let waterfallShownCount = 0;

        function renderWaterfall(append = false) {
            if (!waterfallGrid) return;
            if (!append) {
                waterfallGrid.innerHTML = '';
                waterfallShownCount = 0;
            }

            const nextCount = Math.min(waterfallShownCount + waterfallBatchSize, waterfallBlocks.length);
            for (let i = waterfallShownCount; i < nextCount; i++) {
                const item = document.createElement('div');
                item.className = 'waterfall-item';
                item.innerHTML = `<div class="waterfall-block" style="height:${waterfallBlocks[i].height}px;background:${waterfallBlocks[i].color};"></div>`;
                waterfallGrid.appendChild(item);
            }
            waterfallShownCount = nextCount;

            if (waterfallMoreBtn instanceof HTMLButtonElement) {
                const hasMore = waterfallShownCount < waterfallBlocks.length;
                waterfallMoreBtn.disabled = !hasMore;
                waterfallMoreBtn.textContent = hasMore ? '点开显示更多' : '已展示全部';
            }
        }

        function setWaterfallMode(isWaterfall: boolean) {
            if (workGridWrap) workGridWrap.style.display = isWaterfall ? 'none' : '';
            if (waterfallPanel) waterfallPanel.classList.toggle('active', isWaterfall);
            if (isWaterfall && waterfallShownCount === 0) renderWaterfall();
        }

        function filterWorks(type: string, button: HTMLElement | null) {
            const cards = document.querySelectorAll<HTMLElement>('.project-card');
            const buttons = document.querySelectorAll<HTMLElement>('.filter-btn');

            buttons.forEach(btn => btn.classList.remove('active'));
            if (button) {
                button.classList.add('active');
            }

            if (type === 'waterfall') {
                setWaterfallMode(true);
                return;
            }

            setWaterfallMode(false);

            cards.forEach(card => {
                if (type === 'all' || card.dataset.type === type) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        document.querySelectorAll<HTMLElement>('.filter-btn').forEach(button => {
            button.addEventListener('click', () => {
                filterWorks(button.dataset.filter || 'all', button);
            });
        });

        const defaultFilterBtn = document.querySelector<HTMLElement>('.filter-btn.active');
        if (defaultFilterBtn) {
            filterWorks(defaultFilterBtn.dataset.filter || 'all', defaultFilterBtn);
        }

        waterfallMoreBtn?.addEventListener('click', () => {
            renderWaterfall(true);
        });

        const chartPreview = document.getElementById('chartPreview');
        const overlay = document.getElementById('lightboxOverlay');
        const lightboxGallery = document.getElementById('lightboxGallery');
        const lightboxCaption = document.getElementById('lightboxCaption');
        const lightboxClose = document.getElementById('lightboxClose');
        const lightboxPrev = document.getElementById('lightboxPrev');
        const lightboxNext = document.getElementById('lightboxNext');
        let currentLightboxImages: string[] = [];
        let currentLightboxIndex = 0;

        function openLightbox(images: string[], index = 0) {
            if (!overlay || !lightboxGallery || !lightboxCaption) return;
            currentLightboxImages = images;
            currentLightboxIndex = index;
            lightboxGallery.innerHTML = images.map((src, imageIndex) => `
                <img src="${src}" alt="作品图 ${imageIndex + 1}" loading="lazy">
            `).join('');
            const scrollArea = lightboxGallery.parentElement as HTMLElement | null;
            lightboxCaption.textContent = images.length > 1 ? `共 ${images.length} 张，向下滚动查看` : '作品大图';
            overlay.classList.add('active');
            requestAnimationFrame(() => {
                const targetImage = lightboxGallery.querySelectorAll<HTMLImageElement>('img')[currentLightboxIndex];
                targetImage?.scrollIntoView({ behavior: 'auto', block: 'start' });
                if (scrollArea) scrollArea.scrollTop = 0;
            });
        }

        function closeLightbox() {
            if (overlay) overlay.classList.remove('active');
        }

        function showLightboxImage(index: number) {
            if (!lightboxGallery || !lightboxCaption || !currentLightboxImages.length) return;
            currentLightboxIndex = (index + currentLightboxImages.length) % currentLightboxImages.length;
            const targetImage = lightboxGallery.querySelectorAll<HTMLImageElement>('img')[currentLightboxIndex];
            targetImage?.scrollIntoView({ behavior: 'smooth', block: 'start' });
            lightboxCaption.textContent = currentLightboxImages.length > 1 ? `作品图 ${currentLightboxIndex + 1}/${currentLightboxImages.length}` : '作品大图';
        }

        function getProjectGalleryImages(card: HTMLElement) {
            const baseImages = [
                'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1495707902641-75cac588d2e9?auto=format&fit=crop&w=600&q=80',
                'https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=600&q=80'
            ];
            const customImages = JSON.parse(card.dataset.images || '[]') as string[];
            const sourceImages = customImages.length ? customImages : baseImages;
            return Array.from({ length: 25 }, (_, index) => `${sourceImages[index % sourceImages.length]}&sig=${index}`);
        }

        document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
            card.addEventListener('click', () => {
                const isExpanded = card.classList.contains('expanded');
                document.querySelectorAll<HTMLElement>('.project-card').forEach(otherCard => {
                    otherCard.classList.remove('expanded');
                    const gallery = otherCard.querySelector<HTMLElement>('.project-gallery');
                    if (gallery) gallery.innerHTML = '';
                });

                if (!isExpanded) {
                    card.classList.add('expanded');
                    const images = getProjectGalleryImages(card);
                    const gallery = card.querySelector<HTMLElement>('.project-gallery');
                    if (gallery && images.length) {
                        const previewImage = images[0];
                        gallery.innerHTML = `
                            <div class="project-gallery-preview compact-preview">
                                <div class="main-preview"><img src="${previewImage}" alt="作品主图"></div>
                            </div>
                        `;
                        gallery.querySelectorAll<HTMLImageElement>('img').forEach((img, index) => {
                            img.addEventListener('click', (event) => {
                                event.stopPropagation();
                                openLightbox(images, index);
                            });
                        });
                    }
                }
            });
        });

        document.querySelectorAll<HTMLElement>('.rank-item').forEach(item => {
            item.addEventListener('click', () => {
                const isExpanded = item.classList.contains('expanded');
                document.querySelectorAll<HTMLElement>('.rank-item').forEach(otherItem => {
                    otherItem.classList.remove('expanded');
                    const gallery = otherItem.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery) gallery.innerHTML = '';
                });

                if (!isExpanded) {
                    item.classList.add('expanded');
                    const images = JSON.parse(item.dataset.images || '[]') as string[];
                    const gallery = item.querySelector<HTMLElement>('.rank-gallery');
                    if (gallery && images.length) {
                        const displayImages = Array.from({ length: 25 }, (_, index) => `${images[index % images.length]}&sig=${index}`);
                        gallery.innerHTML = displayImages.slice(0, 10).map((src, index) => {
                            if (index === 9) {
                                return `<div class="gallery-more">+${displayImages.length - 9} 张</div>`;
                            }
                            return `<img src="${src}" alt="爆款案例图片" data-index="${index}">`;
                        }).join('');
                        gallery.querySelectorAll<HTMLImageElement>('img').forEach((img, index) => {
                            img.addEventListener('click', (event) => {
                                event.stopPropagation();
                                openLightbox(displayImages, index);
                            });
                        });
                    }
                }
            });
        });

        if (chartPreview) {
            chartPreview.addEventListener('click', () => {
                openLightbox([
                    'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1400&q=80'
                ], 0);
            });
        }

        if (overlay) {
            overlay.addEventListener('click', (event) => {
                if (event.target === overlay) closeLightbox();
            });
        }
        if (lightboxClose) lightboxClose.addEventListener('click', closeLightbox);
        if (lightboxPrev) lightboxPrev.addEventListener('click', () => showLightboxImage(currentLightboxIndex - 1));
        if (lightboxNext) lightboxNext.addEventListener('click', () => showLightboxImage(currentLightboxIndex + 1));
        document.addEventListener('keydown', (event) => {
            if (!overlay?.classList.contains('active')) return;
            if (event.key === 'Escape') closeLightbox();
            if (event.key === 'ArrowRight') showLightboxImage(currentLightboxIndex + 1);
            if (event.key === 'ArrowLeft') showLightboxImage(currentLightboxIndex - 1);
        });

        // === 移动端横向翻页/分页控制（仅在窄屏可见） ===
        (function() {
            const workGrid = document.getElementById('workGrid');
            if (!workGrid) return;
            const wrap = workGrid.parentElement;
            const prevBtn = wrap?.querySelector('.scroll-btn.prev');
            const nextBtn = wrap?.querySelector('.scroll-btn.next');
            const dotsWrap = wrap?.querySelector('.page-dots');

            function getPages() {
                const pageWidth = workGrid.clientWidth || window.innerWidth;
                return Math.max(1, Math.ceil(workGrid.scrollWidth / pageWidth));
            }

            function updateDots() {
                if (!dotsWrap) return;
                const pages = getPages();
                const current = Math.round((workGrid.scrollLeft || 0) / (workGrid.clientWidth || window.innerWidth));
                dotsWrap.innerHTML = '';
                for (let i = 0; i < pages; i++) {
                    const btn = document.createElement('button');
                    btn.className = 'dot' + (i === current ? ' active' : '');
                    btn.dataset.index = String(i);
                    dotsWrap.appendChild(btn);
                }
            }

            function scrollToPage(index) {
                const left = (workGrid.clientWidth || window.innerWidth) * index;
                workGrid.scrollTo({ left, behavior: 'smooth' });
            }

            prevBtn?.addEventListener('click', () => { scrollToPage(Math.max(0, Math.round(workGrid.scrollLeft / workGrid.clientWidth) - 1)); });
            nextBtn?.addEventListener('click', () => { scrollToPage(Math.min(getPages() - 1, Math.round(workGrid.scrollLeft / workGrid.clientWidth) + 1)); });
            dotsWrap?.addEventListener('click', (e) => {
                const t = e.target;
                if (t && t.dataset && t.dataset.index) scrollToPage(Number(t.dataset.index));
            });

            workGrid.addEventListener('scroll', () => { requestAnimationFrame(updateDots); });
            window.addEventListener('resize', () => { requestAnimationFrame(updateDots); });
            // 初始化
            setTimeout(updateDots, 200);
        })();

        // === 原生 JS 数字滚动动画 ===
        function animateCountUp(el: HTMLElement) {
            const target = parseInt(el.dataset.target || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 2000; // 2秒动画
            const step = target / (duration / 16); // 每帧增加的数值
            let current = 0;

            const timer = setInterval(() => {
                current += step;
                if (current >= target) {
                    el.innerText = target + suffix;
                    clearInterval(timer);
                } else {
                    el.innerText = Math.ceil(current) + suffix;
                }
            }, 16);
        }

        // === 监听滚动触发数字动画 ===
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting && entry.target instanceof HTMLElement) {
                    animateCountUp(entry.target);
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.count-up').forEach(el => observer.observe(el));

        // === 编辑模式开关 ===
        let clickCount = 0;
        let clickTimer: ReturnType<typeof setTimeout> | null = null;
        const logo = document.getElementById('logo-trigger');
        const indicator = document.getElementById('edit-mode-indicator');

        if (logo) {
            logo.addEventListener('click', () => {
                clickCount++;
                if (clickCount === 1) {
                    clickTimer = setTimeout(() => {
                        clickCount = 0;
                    }, 1000); // 1秒内点击3次
                } else if (clickCount === 3) {
                    if (clickTimer) clearTimeout(clickTimer);
                    clickCount = 0;
                    
                    const isEditable = document.body.contentEditable === 'true';
                    document.body.contentEditable = isEditable ? 'false' : 'true';
                    
                    if (indicator) {
                        indicator.style.display = isEditable ? 'none' : 'block';
                        setTimeout(() => {
                            if (!isEditable && indicator) indicator.style.display = 'none';
                        }, 2000);
                    }
                }
            });
        }

        // === 移动端导航 开关 ===
        const mobileToggle = document.getElementById('mobile-nav-toggle');
        const mobileNav = document.getElementById('mobileNav');
        const mobileCloseBtn = document.getElementById('mobileNavClose');
        function openMobileNav() {
            if (mobileNav) {
                mobileNav.classList.add('open');
                mobileNav.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            }
        }
        function closeMobileNav() {
            if (mobileNav) {
                mobileNav.classList.remove('open');
                mobileNav.setAttribute('aria-hidden', 'true');
                document.body.style.overflow = '';
            }
        }
        mobileToggle?.addEventListener('click', openMobileNav);
        mobileCloseBtn?.addEventListener('click', closeMobileNav);
        document.querySelectorAll('.mobile-nav a').forEach(a => a.addEventListener('click', closeMobileNav));
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMobileNav(); });
        // contact avatar replace & copy wechat
        const contactAvatar = document.getElementById('contactAvatar') as HTMLImageElement | null;
        const contactAvatarWrap = document.getElementById('contactAvatarWrap');
        const copyWeChatBtn = document.getElementById('copyWeChat');
        // load saved avatar
        try {
            const saved = localStorage.getItem('contactAvatarSrc');
            if (saved && contactAvatar) contactAvatar.src = saved;
        } catch (e) { }
        contactAvatarWrap?.addEventListener('click', (e) => {
            e.preventDefault();
            const url = prompt('请输入头像图片 URL（以 http/https 开头）：', contactAvatar?.src || '');
            if (url && contactAvatar) {
                contactAvatar.src = url;
                try { localStorage.setItem('contactAvatarSrc', url); } catch (err) { }
            }
        });
        copyWeChatBtn?.addEventListener('click', (e) => {
            e.preventDefault();
            const text = 'YIYUANYUYU';
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text).then(() => alert('WeChat 已复制：' + text));
            } else {
                alert('请手动复制：' + text);
            }
        });
    </script>
</body>
</html>