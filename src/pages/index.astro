import fs from 'node:fs/promises';
import path from 'node:path';
import sharp from 'sharp';

type MainProjectCard = {
    folderName: string;
    coverSrc: string;
    images: string[];
    videos: string[];
    previewVideoSrc?: string;
    previewVideoMime?: string;
    imageCount: number;
    sortTime: number;
};

type WaterfallImage = {
    src: string;
    alt: string;
    folderLabel: string;
};

type ResponsiveImageData = {
    src: string;
    srcset?: string;
    width?: number;
    height?: number;
};

const publicRoot = path.resolve(process.cwd(), 'public');
const mainProjectsRoot = path.join(publicRoot, '2c', '2y');
const aplusProjectsRoot = path.join(publicRoot, '2c', '3q');
const brandProjectsRoot = path.join(publicRoot, '2c', '5p');
const packagingProjectsRoot = path.join(publicRoot, '2c', '6b');
const cesProjectsRoot = path.join(publicRoot, '2c', '7x');
const otherProjectsRoot = path.join(publicRoot, '2c', '8q');
const waterfallRoot = path.join(publicRoot, '2c', '1p');
const responsiveOutputRoot = path.join(publicRoot, '__responsive');
const imageExtensions = new Set(['.jpg', '.jpeg', '.png', '.webp', '.gif', '.avif']);
const videoExtensions = new Set(['.mp4', '.webm', '.mov']);
const responsiveVariantWidths = [240, 360, 480, 640, 960, 1280];
const responsiveImageCache = new Map<string, Promise<ResponsiveImageData>>();

const imageSizes = {
    waterfall: '(max-width: 480px) 50vw, (max-width: 768px) 33vw, (max-width: 1200px) 20vw, 280px',
    card: '(max-width: 480px) 50vw, (max-width: 768px) 33vw, (max-width: 1200px) 25vw, 280px',
    heroBadge: '80px',
    methodology: '(max-width: 480px) 100vw, (max-width: 992px) 92vw, 1100px',
    avatar: '96px',
    lightbox: '100vw',
};

function toPublicUrl(absolutePath: string) {
    return encodeURI('/' + path.relative(publicRoot, absolutePath).split(path.sep).join('/'));
}

function isRemoteImageUrl(src: string) {
    return /^https?:\/\//i.test(src);
}

function isLocalPublicImageUrl(src: string) {
    return src.startsWith('/') && !src.startsWith('//');
}

function normalizePublicUrl(src: string) {
    if (!src.startsWith('/')) return src;
    return encodeURI(decodeURI(src));
}

function getAbsolutePathFromPublicUrl(src: string) {
    return path.join(publicRoot, decodeURI(src.replace(/^\//, '')));
}

async function fileExists(targetPath: string) {
    try {
        await fs.access(targetPath);
        return true;
    } catch {
        return false;
    }
}

function getResponsiveVariantUrl(src: string, width: number, extension: string) {
    const relativePath = decodeURI(src.replace(/^\//, ''));
    const parsed = path.parse(relativePath);
    const variantRelativePath = path.join('__responsive', parsed.dir, `${parsed.name}-w${width}${extension}`);
    return encodeURI('/' + variantRelativePath.split(path.sep).join('/'));
}

function getSharpFormat(extension: string) {
    const normalized = extension.toLowerCase();
    if (normalized === '.jpg' || normalized === '.jpeg') return 'jpeg';
    if (normalized === '.png') return 'png';
    if (normalized === '.webp') return 'webp';
    if (normalized === '.avif') return 'avif';
    return null;
}

async function createLocalResponsiveImageData(src: string): Promise<ResponsiveImageData> {
    const normalizedSrc = normalizePublicUrl(src);
    const absolutePath = getAbsolutePathFromPublicUrl(normalizedSrc);
    const metadata = await sharp(absolutePath).metadata();

    if (!metadata.width || !metadata.height) {
        return { src: normalizedSrc };
    }

    const extension = path.extname(absolutePath).toLowerCase();
    const sharpFormat = getSharpFormat(extension);

    if (!sharpFormat || extension === '.gif') {
        return {
            src: normalizedSrc,
            width: metadata.width,
            height: metadata.height,
        };
    }

    const candidateWidths = responsiveVariantWidths.filter((width) => width < metadata.width);
    const parsed = path.parse(getAbsolutePathFromPublicUrl(normalizedSrc));
    const variantDir = path.join(responsiveOutputRoot, path.relative(publicRoot, parsed.dir));
    await fs.mkdir(variantDir, { recursive: true });

    const generatedEntries = await Promise.all(
        candidateWidths.map(async (width) => {
            const outputPath = path.join(variantDir, `${parsed.name}-w${width}${extension}`);
            if (!(await fileExists(outputPath))) {
                let pipeline = sharp(absolutePath).rotate().resize({ width, withoutEnlargement: true });
                if (sharpFormat === 'jpeg') pipeline = pipeline.jpeg({ quality: 82, mozjpeg: true });
                if (sharpFormat === 'png') pipeline = pipeline.png({ compressionLevel: 9, palette: true });
                if (sharpFormat === 'webp') pipeline = pipeline.webp({ quality: 82 });
                if (sharpFormat === 'avif') pipeline = pipeline.avif({ quality: 60 });
                await pipeline.toFile(outputPath);
            }

            return `${getResponsiveVariantUrl(normalizedSrc, width, extension)} ${width}w`;
        })
    );

    const srcsetEntries = [...generatedEntries, `${normalizedSrc} ${metadata.width}w`];

    return {
        src: normalizedSrc,
        srcset: srcsetEntries.join(', '),
        width: metadata.width,
        height: metadata.height,
    };
}

function buildUnsplashResponsiveData(src: string): ResponsiveImageData {
    const url = new URL(src);
    const originalWidth = Number(url.searchParams.get('w') || '1600');
    const widths = responsiveVariantWidths.filter((width) => width < originalWidth);
    const srcset = [...widths, originalWidth]
        .map((width) => {
            const variant = new URL(url.toString());
            variant.searchParams.set('w', String(width));
            return `${variant.toString()} ${width}w`;
        })
        .join(', ');
    return { src, srcset, width: originalWidth };
}

function buildPlaceholdResponsiveData(src: string): ResponsiveImageData {
    const url = new URL(src);
    const match = url.pathname.match(/\/(\d+)x(\d+)(?=\/|$)/i);
    if (!match) return { src };

    const originalWidth = Number(match[1]);
    const originalHeight = Number(match[2]);
    const widths = responsiveVariantWidths.filter((width) => width < originalWidth);
    const srcset = [...widths, originalWidth]
        .map((width) => {
            const height = Math.round((originalHeight / originalWidth) * width);
            return `${src.replace(`/${originalWidth}x${originalHeight}/`, `/${width}x${height}/`)} ${width}w`;
        })
        .join(', ');

    return {
        src,
        srcset,
        width: originalWidth,
        height: originalHeight,
    };
}

async function getResponsiveImageData(src: string): Promise<ResponsiveImageData> {
    if (!src) return { src };

    if (!responsiveImageCache.has(src)) {
        responsiveImageCache.set(
            src,
            (async () => {
                if (isLocalPublicImageUrl(src)) {
                    return createLocalResponsiveImageData(src);
                }

                if (/^https?:\/\/images\.unsplash\.com\//i.test(src)) {
                    return buildUnsplashResponsiveData(src);
                }

                if (/^https?:\/\/placehold\.co\//i.test(src)) {
                    return buildPlaceholdResponsiveData(src);
                }

                return { src };
            })()
        );
    }

    return responsiveImageCache.get(src)!;
}

function responsiveImgAttrs(data: ResponsiveImageData | undefined, sizes: string, loading: 'lazy' | 'eager' = 'lazy') {
    if (!data) return { sizes, loading, decoding: 'async' as const };
    return {
        src: data.src,
        srcset: data.srcset,
        sizes,
        width: data.width,
        height: data.height,
        loading,
        decoding: 'async' as const,
    };
}

function getVideoMimeType(fileName: string) {
    const ext = path.extname(fileName).toLowerCase();
    if (ext === '.webm') return 'video/webm';
    if (ext === '.mov') return 'video/quicktime';
    return 'video/mp4';
}

async function loadProjectCards(rootPath: string): Promise<MainProjectCard[]> {
    const monthEntries = await fs.readdir(rootPath, { withFileTypes: true });
    const projectFolders: Array<{ folderName: string; folderPath: string }> = [];

    for (const monthEntry of monthEntries) {
        if (!monthEntry.isDirectory()) continue;

        const monthPath = path.join(rootPath, monthEntry.name);
        const folderEntries = await fs.readdir(monthPath, { withFileTypes: true });

        for (const folderEntry of folderEntries) {
            if (!folderEntry.isDirectory()) continue;
            projectFolders.push({
                folderName: folderEntry.name,
                folderPath: path.join(monthPath, folderEntry.name),
            });
        }
    }

    // Fallback: some categories use one-level folders directly under root.
    if (!projectFolders.length) {
        for (const entry of monthEntries) {
            if (!entry.isDirectory()) continue;
            const folderPath = path.join(rootPath, entry.name);
            const childEntries = await fs.readdir(folderPath, { withFileTypes: true });
            const hasSupportedMediaFiles = childEntries.some(
                (child) =>
                    child.isFile() &&
                    (imageExtensions.has(path.extname(child.name).toLowerCase()) || videoExtensions.has(path.extname(child.name).toLowerCase()))
            );
            if (!hasSupportedMediaFiles) continue;
            projectFolders.push({
                folderName: entry.name,
                folderPath,
            });
        }
    }

    const projectCards = await Promise.all(
        projectFolders.map(async ({ folderName, folderPath }): Promise<MainProjectCard | null> => {
            const fileEntries = await fs.readdir(folderPath, { withFileTypes: true });
            const fileNames = fileEntries
                .filter((entry) => entry.isFile())
                .map((entry) => entry.name)
                .sort((left, right) => left.localeCompare(right, 'zh-Hans-CN', { numeric: true, sensitivity: 'base' }))
            const images = fileNames
                .filter((fileName) => imageExtensions.has(path.extname(fileName).toLowerCase()))
                .map((fileName) => toPublicUrl(path.join(folderPath, fileName)));
            const videoFileNames = fileNames.filter((fileName) => videoExtensions.has(path.extname(fileName).toLowerCase()));
            const videos = videoFileNames.map((fileName) => toPublicUrl(path.join(folderPath, fileName)));
            const previewVideoFileName = videoFileNames[0];
            const previewVideoSrc = previewVideoFileName ? toPublicUrl(path.join(folderPath, previewVideoFileName)) : undefined;
            const previewVideoMime = previewVideoFileName ? getVideoMimeType(previewVideoFileName) : undefined;
            const coverSrc = images[0] ?? previewVideoSrc;

            if (!coverSrc) return null;

            const card: MainProjectCard = {
                folderName,
                coverSrc,
                images,
                videos,
                imageCount: images.length,
                sortTime: (await fs.stat(folderPath)).mtimeMs,
            };

            if (previewVideoSrc) {
                card.previewVideoSrc = previewVideoSrc;
                card.previewVideoMime = previewVideoMime;
            }

            return card;
        })
    );

    return projectCards
        .filter((card): card is MainProjectCard => Boolean(card))
        .sort((left, right) => right.sortTime - left.sortTime || left.folderName.localeCompare(right.folderName, 'zh-Hans-CN', { numeric: true, sensitivity: 'base' }));
}

async function loadWaterfallImages(rootPath: string): Promise<WaterfallImage[]> {
    const images: WaterfallImage[] = [];

    async function walkDirectory(currentPath: string, folderTrail: string[] = []) {
        const entries = await fs.readdir(currentPath, { withFileTypes: true });

        for (const entry of entries) {
            const entryPath = path.join(currentPath, entry.name);
            if (entry.isDirectory()) {
                await walkDirectory(entryPath, [...folderTrail, entry.name]);
                continue;
            }

            if (!entry.isFile()) continue;
            if (!imageExtensions.has(path.extname(entry.name).toLowerCase())) continue;

            const folderLabel = folderTrail.length ? folderTrail.join(' / ') : path.basename(rootPath);
            images.push({
                src: toPublicUrl(entryPath),
                alt: `${folderLabel} - ${entry.name}`,
                folderLabel,
            });
        }
    }

    await walkDirectory(rootPath);

    return images.sort((left, right) => left.alt.localeCompare(right.alt, 'zh-Hans-CN', { numeric: true, sensitivity: 'base' }));
}

const mainProjectCards = await loadProjectCards(mainProjectsRoot);
const aplusProjectCards = await loadProjectCards(aplusProjectsRoot);
const brandProjectCards = await loadProjectCards(brandProjectsRoot);
const packagingProjectCards = await loadProjectCards(packagingProjectsRoot);
const cesProjectCards = await loadProjectCards(cesProjectsRoot);
const otherProjectCards = await loadProjectCards(otherProjectsRoot);
const waterfallImages = await loadWaterfallImages(waterfallRoot);

const allProjectCards = [
    ...mainProjectCards,
    ...aplusProjectCards,
    ...brandProjectCards,
    ...packagingProjectCards,
    ...cesProjectCards,
    ...otherProjectCards,
];

const responsiveSourceUrls = new Set<string>([
    '/1shouye/1ya.png',
    '/1shouye/methodology-reference.png',
    '/tex/toux.jpg',
    ...waterfallImages.map((image) => image.src),
    ...allProjectCards.flatMap((card) => [card.coverSrc, ...card.images]),
    'https://images.unsplash.com/photo-1495707902641-75cac588d2e9?auto=format&fit=crop&w=600&q=80',
    'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80',
    'https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=600&q=80',
    'https://placehold.co/400x300/9b59b6/fff?text=Video+1',
    'https://placehold.co/400x300/a569bd/fff?text=Video+2',
    'https://placehold.co/400x300/b784c9/fff?text=Video+3',
    'https://placehold.co/400x300/c59fd6/fff?text=Video+4',
    'https://placehold.co/400x300/d3b0e3/fff?text=Video+5',
    'https://placehold.co/400x300/4a90e2/fff?text=Robot+Vacuum',
    'https://placehold.co/400x300/ff6b6b/fff?text=Hair+Dryer',
    'https://placehold.co/400x300/2ecc71/fff?text=Air+Purifier',
    'https://placehold.co/400x300/9b59b6/fff?text=Portable+Fan',
    'https://placehold.co/400x300/34495e/fff?text=Coffee+Maker',
    'https://placehold.co/400x300/f39c12/fff?text=Massage+Gun',
    'https://placehold.co/400x300/1abc9c/fff?text=Security+Cam',
    'https://placehold.co/400x300/7f8c8d/fff?text=Desk+Lamp',
    'https://placehold.co/400x300/e67e22/fff?text=Water+Bottle',
    'https://placehold.co/400x300/95a5a6/fff?text=Travel+Bag',
    'https://placehold.co/400x300/00b894/fff?text=Kitchen+Scale',
    'https://placehold.co/400x300/6c5ce7/fff?text=Bluetooth+Speaker',
    'https://placehold.co/400x300/0984e3/fff?text=Phone+Stand',
    'https://placehold.co/400x300/bc6c25/fff?text=Car+Vacuum',
    'https://placehold.co/400x300/d63031/fff?text=Sleep+Mask',
    'https://placehold.co/400x300/2d3436/fff?text=Mini+Projector',
    'https://placehold.co/400x300/8e44ad/fff?text=Smart+Scale',
    'https://placehold.co/400x300/1e3799/fff?text=Desk+Fan',
    'https://placehold.co/400x300/27ae60/fff?text=Air+Fryer',
    'https://placehold.co/400x300/ff7675/fff?text=Hair+Curler',
    'https://placehold.co/400x300/00cec9/fff?text=USB+Hub',
    'https://placehold.co/400x300/636e72/fff?text=Pet+Camera',
    'https://placehold.co/400x300/e17055/fff?text=Water+Flosser',
    'https://placehold.co/400x300/74b9ff/fff?text=LED+Lamp',
    'https://placehold.co/400x300/55efc4/fff?text=Smart+Plug',
    'https://placehold.co/400x300/ff9f1c/fff?text=Electric+Toothbrush',
    'https://placehold.co/400x300/81ecec/fff?text=Robot+Mop',
    'https://placehold.co/400x300/6ab04c/fff?text=Portable+Charger',
    'https://placehold.co/400x300/fd79a8/fff?text=Beauty+Tool',
]);

const responsiveImageEntries = await Promise.all(
    Array.from(responsiveSourceUrls).map(async (src) => [src, await getResponsiveImageData(src)] as const)
);

const responsiveImageCatalog = new Map<string, ResponsiveImageData>(responsiveImageEntries);
const runtimeResponsiveImageCatalog = Object.fromEntries(responsiveImageEntries);

function getCatalogImageAttrs(src: string, sizes: string, loading: 'lazy' | 'eager' = 'lazy') {
    return responsiveImgAttrs(responsiveImageCatalog.get(src), sizes, loading);
}
